<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>bitcandy - 비트캔디</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Pretendard:wght@400;700;900&display=swap');
        body { font-family: 'Pretendard', sans-serif; background-color: #f8fafc; color: #334155; margin: 0; }
        .page { display: none; }
        .active { display: block; }
    </style>
</head>
<body>
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
        <div class="max-w-4xl mx-auto px-4 h-16 flex justify-between items-center">
            <div class="text-2xl font-black cursor-pointer" onclick="location.reload()">bitcandy</div>
            <div class="flex gap-4">
                <button onclick="showPage('login')" class="text-sm font-bold text-slate-500">로그인</button>
                <button onclick="showPage('register')" class="bg-slate-800 text-white px-4 py-2 rounded-lg text-sm font-bold">회원가입</button>
            </div>
        </div>
    </nav>

    <div class="max-w-4xl mx-auto px-4 py-8">
        <section id="main" class="page active">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-bold">전체 게시판</h2>
                <button onclick="showPage('write')" class="bg-slate-800 text-white px-4 py-2 rounded-lg font-bold">글쓰기</button>
            </div>
            <div class="bg-white border border-slate-200 rounded-xl divide-y divide-slate-100 shadow-sm">
                <div class="p-6 hover:bg-slate-50 cursor-pointer flex gap-4" onclick="showPage('postDetail')">
                    <div class="flex flex-col items-center text-slate-400">
                        <span>▲</span><span class="font-bold text-slate-800">12</span><span>▼</span>
                    </div>
                    <div>
                        <h3 class="font-bold text-lg">비트캔디에 오신 것을 환영합니다.</h3>
                        <p class="text-slate-500 text-sm">자유로운 소통의 장입니다.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="postDetail" class="page">
            <button onclick="showPage('main')" class="mb-4 text-slate-400 font-bold">← 뒤로가기</button>
            <div class="bg-white border border-slate-200 rounded-xl p-8 shadow-sm">
                <h2 class="text-2xl font-bold mb-4">비트캔디에 오신 것을 환영합니다.</h2>
                <p class="text-slate-600 leading-relaxed mb-8">여기에 게시글 내용이 들어옵니다.</p>
                <div class="border-t pt-6">
                    <h4 class="font-bold mb-4">댓글 작성</h4>
                    <textarea class="w-full p-4 border rounded-xl bg-slate-50 mb-2" placeholder="댓글을 남겨주세요"></textarea>
                    <div class="flex justify-end"><button class="bg-slate-800 text-white px-4 py-2 rounded-lg">등록</button></div>
                </div>
            </div>
        </section>

        <section id="write" class="page">
            <div class="bg-white border border-slate-200 rounded-xl p-8 shadow-sm">
                <h2 class="text-xl font-bold mb-6">새 글 작성</h2>
                <input type="text" placeholder="제목" class="w-full p-4 border rounded-xl mb-4 bg-slate-50">
                <textarea rows="8" placeholder="내용" class="w-full p-4 border rounded-xl mb-4 bg-slate-50"></textarea>
                <div class="flex gap-4">
                    <button onclick="showPage('main')" class="flex-1 font-bold text-slate-400">취소</button>
                    <button onclick="showPage('main')" class="flex-1 bg-slate-800 text-white py-4 rounded-xl font-bold">등록하기</button>
                </div>
            </div>
        </section>

        <section id="login" class="page">
            <div class="max-w-sm mx-auto bg-white border border-slate-200 rounded-xl p-8 mt-10 shadow-sm">
                <h2 class="text-2xl font-bold text-center mb-8">bitcandy 로그인</h2>
                <input type="text" placeholder="ID" class="w-full p-4 border rounded-xl mb-4">
                <input type="password" placeholder="Password" class="w-100 p-4 border rounded-xl mb-6">
                <button class="w-full bg-slate-800 text-white py-4 rounded-xl font-bold">접속</button>
            </div>
        </section>
    </div>

    <script>
        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
            window.scrollTo(0,0);
        }
    </script>
</body>
</html>
